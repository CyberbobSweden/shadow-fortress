; Engine configuration file for Project Shadow Fortress.
; Godot 4.x. Open this folder in Godot to load autoloads + input map.

config_version=5

[application]

config/name="Shadow Fortress"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

EventBus="*res://autoload/EventBus.gd"
Encounter="*res://autoload/EncounterCoordinator.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

move_left={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":65},
{"type":"joypad_motion","axis":0,"axis_value":-1.0}
]
}
move_right={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":68},
{"type":"joypad_motion","axis":0,"axis_value":1.0}
]
}
run={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":4194325},
{"type":"joypad_button","button_index":10}
]
}
sneak={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":4194326},
{"type":"joypad_button","button_index":11}
]
}
guard={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":75},
{"type":"joypad_button","button_index":4}
]
}
light_punch={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":74},
{"type":"joypad_button","button_index":0}
]
}
heavy_punch={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":85},
{"type":"joypad_button","button_index":1}
]
}
front_kick={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":73},
{"type":"joypad_button","button_index":2}
]
}
roundhouse={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":79},
{"type":"joypad_button","button_index":3}
]
}
sweep={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":76},
{"type":"joypad_button","button_index":5}
]
}

[rendering]

textures/canvas_textures/default_texture_filter=0
